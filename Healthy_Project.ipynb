import json

notebook1 = {
 "cells": [
  {
   "cell_type": "code",
   "execution_count": None,
   "id": "cell_1",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.preprocessing import StandardScaler"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": None,
   "id": "cell_2",
   "metadata": {},
   "outputs": [],
   "source": [
    "def clean_and_preprocess_data(df: pd.DataFrame, fill_strategy: str = 'median') -> pd.DataFrame:\n",
    "    cleaned_df = df.copy()\n",
    "    \n",
    "    if fill_strategy == 'median':\n",
    "        cleaned_df[\"ca\"] = cleaned_df[\"ca\"].fillna(cleaned_df[\"ca\"].median())\n",
    "        cleaned_df[\"thal\"] = cleaned_df[\"thal\"].fillna(cleaned_df[\"thal\"].median())\n",
    "    else:\n",
    "        cleaned_df[\"ca\"] = cleaned_df[\"ca\"].fillna(0)\n",
    "        cleaned_df[\"thal\"] = cleaned_df[\"thal\"].fillna(0)\n",
    "\n",
    "    target_map = {0: 0, 1: 1, 2: 1, 3: 1, 4: 1}\n",
    "    cleaned_df[\"target\"] = cleaned_df[\"target\"].map(target_map)\n",
    "\n",
    "    Q1 = cleaned_df['chol'].quantile(0.25)\n",
    "    Q3 = cleaned_df['chol'].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    lower_bound = Q1 - 1.5 * IQR\n",
    "    upper_bound = Q3 + 1.5 * IQR\n",
    "    \n",
    "    cleaned_df['chol'] = np.clip(cleaned_df['chol'], lower_bound, upper_bound)\n",
    "\n",
    "    cleaned_df = pd.get_dummies(cleaned_df, columns=['cp', 'restecg', 'slope'], drop_first=True, dtype=int)\n",
    "\n",
    "    scaler = StandardScaler()\n",
    "    num_cols = ['age', 'trestbps', 'chol', 'thalach', 'oldpeak']\n",
    "    cleaned_df[num_cols] = scaler.fit_transform(cleaned_df[num_cols])\n",
    "\n",
    "    return cleaned_df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": None,
   "id": "cell_3",
   "metadata": {},
   "outputs": [],
   "source": [
    "column_names = [\"age\", \"sex\", \"cp\", \"trestbps\", \"chol\", \"fbs\", \"restecg\", \n",
    "                \"thalach\", \"exang\", \"oldpeak\", \"slope\", \"ca\", \"thal\", \"target\"]\n",
    "\n",
    "raw_df = pd.read_csv(\"heart.csv\", names=column_names, na_values=\"?\")\n",
    "\n",
    "final_df = clean_and_preprocess_data(raw_df)\n",
    "final_df.to_csv(\"cleaned_heart.csv\", index=False)\n",
    "print(\"Notebook 1 Complete: 'cleaned_heart.csv' created.\")"
   ]
  }
 ],
 "metadata": {
  "language_info": {
   "name": "python"
  }
 },
 "nbformat": 4,
 "nbformat_minor": 5
}

notebook2 = {
 "cells": [
  {
   "cell_type": "code",
   "execution_count": None,
