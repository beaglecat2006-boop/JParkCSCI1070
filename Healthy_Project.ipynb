import numpy as np
import pandas as pd


# 1. This function handles cleaning the data exactly as you provided
def clean_heart_data(df: pd.DataFrame) -> pd.DataFrame:
    cleaned_df = df.copy()

    # Fill missing values with the median
    cleaned_df["ca"] = cleaned_df["ca"].fillna(cleaned_df["ca"].median())
    cleaned_df["thal"] = cleaned_df["thal"].fillna(cleaned_df["thal"].median())

    # Turn severe target indicators into a binary classification (0 or 1)
    cleaned_df["target"] = cleaned_df["target"].apply(
        lambda x: 1 if x > 0 else 0
    )

    return cleaned_df  # Added return statement so function actually works!


# 2. Header names for the columns
column_names = [
    "age",
    "sex",
    "cp",
    "trestbps",
    "chol",
    "fbs",
    "restecg",
    "thalach",
    "exang",
    "oldpeak",
    "slope",
    "ca",
    "thal",
    "target",
]

# 3. Read directly from the web address
raw_df = pd.read_csv(
    "https://archive.ics.uci.edu/ml/machine-learning-databases/heart-disease/processed.cleveland.data",
    names=column_names,
    na_values="?",
)

# 4. Clean and save the file
cleaned_df = clean_heart_data(raw_df)

# Added index=False here to prevent duplicating the row numbers
cleaned_df.to_csv("cleaned_heart.csv", index=False)

print("Notebook 1 Complete: 'cleaned_heart.csv' created.")




